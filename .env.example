# ══════════════════════════════════════════════════════════════
# Mahalaxmi Fashion Hub — Environment Variables
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════

# PostgreSQL
DB_PASSWORD=your_strong_db_password_here

# JWT Secret (min 32 chars, use random string)
JWT_KEY=REPLACE_WITH_LONG_RANDOM_SECRET_KEY_64_CHARS_MINIMUM

# Admin credentials
ADMIN_EMAIL=admin@mahalaxmifashionhub.com
# Generate with: htpasswd -bnBC 12 "" your_password | cut -d: -f2
ADMIN_PASSWORD_HASH=$2a$12$REPLACE_WITH_BCRYPT_HASH

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Delhivery
DELHIVERY_TOKEN=your_delhivery_token
